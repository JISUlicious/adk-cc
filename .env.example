# adk-cc env-var reference. Copy to `.env` and fill in real values.
# `.env` is gitignored; this file is committed.

# =============================================================================
# Model (required for any LLM call)
# =============================================================================

# API key for your model server (required).
ADK_CC_API_KEY=sk-replace-me

# OpenAI-compatible model server. Default: http://localhost:18000/v1
# ADK_CC_API_BASE=http://localhost:18000/v1

# LiteLLM model id. Default: openai/Qwen3.6-35B-A3B-UD-MLX-4bit
# Examples:
#   openai/<model-id>      (LM Studio, vLLM, mlx_lm, llama.cpp servers)
#   ollama_chat/llama3.1:8b
#   anthropic/claude-sonnet-4-5
# ADK_CC_MODEL=openai/Qwen3.6-35B-A3B-UD-MLX-4bit


# =============================================================================
# Permissions (Stage B)
# =============================================================================

# default | plan | acceptEdits | bypassPermissions | dontAsk
# Default for `adk web .` dev: bypassPermissions (preserves the dev experience).
# Production deployments typically use `default` or stricter.
# ADK_CC_PERMISSION_MODE=default


# =============================================================================
# Sandbox (Stage C)
# =============================================================================

# noop (host execution, dev only) | docker | e2b | sandbox_service | daytona
# Default: noop. e2b is still a stub — implement against SandboxBackend
# ABC if needed. sandbox_service delegates to an external REST sandbox
# (JISUlicious/sandboxing or compatible) — see the dedicated block below.
# daytona delegates to a self-hosted Daytona compute plane (see its
# block below).
# ADK_CC_SANDBOX_BACKEND=noop

# Stream run_bash output incrementally to operator-side logs. When set,
# BashTool consumes the backend's exec_stream() instead of exec(): for
# sandbox_service the upstream SSE endpoint delivers chunks live, for
# other backends the ABC default emits one chunk at the end (no behavior
# change). The MODEL still receives one aggregated final result either
# way — this is observability for long-running commands, not a tool-
# surface change. Default: off (existing behavior preserved).
# ADK_CC_BASH_STREAM=1

# Tool-call titles (opt-in). When 1, every tool declaration gains an optional
# `title` arg the model fills with a short human label ("Writing ML training
# script"), shown in the frontend tool cards. Stripped before execution — no
# tool or MCP server ever sees it; the recorded event keeps it for the UI.
# Costs a few output tokens per tool call.
# ADK_CC_TOOL_TITLES=1

# NoopBackend safety: by default refuses to exec in production-shaped
# paths (anything outside $HOME, /tmp, OS tempdirs). Set this to 1 to
# acknowledge that you really want to run commands directly on the
# host. NEVER set this in production — use ADK_CC_SANDBOX_BACKEND=docker
# for real isolation. Same pattern as ADK_CC_ALLOW_NO_AUTH for make_app.
# ADK_CC_NOOP_ACK_HOST_EXEC=1

# Workspace root.
#   - Dev (`adk web .`): a single flat directory. The agent reads/writes
#     here directly. Set to a project-relative or absolute path.
#   - Production (TenancyPlugin): the ROOT under which per-tenant /
#     per-user dirs live. Layout:
#         <root>/<tenant_id>/<user_id>/                  ← persistent home
#         <root>/<tenant_id>/<user_id>/.sessions/<sid>/  ← per-session scratch
#         <root>/<tenant_id>/<user_id>/.cache/           ← per-user install cache
# For NoopBackend this is a path on the agent host; for DockerBackend it
# must be a path on the SANDBOX VM (where the container bind-mounts it).
# ADK_CC_WORKSPACE_ROOT=/var/lib/adk-cc/wks

# Per-session scratch retention (days). Only applies in production
# (per-user layout). The scratch_reaper script (scripts/scratch_reaper.py)
# wipes session scratch dirs older than this. User home dirs persist
# forever regardless. Defaults to 7.
# ADK_CC_SESSION_SCRATCH_RETENTION_DAYS=7

# Disable the per-user install cache bind-mount (production only). When
# unset (default), DockerBackend bind-mounts <user_home>/.cache to
# /root/.cache inside the sandbox container so uv/pip caches survive
# across the user's sessions. Set to 1 if you want truly stateless
# containers (every session reinstalls everything from network).
# ADK_CC_DISABLE_INSTALL_CACHE_MOUNT=1

# --- Sandbox environment + secrets (backend-agnostic) ---
# Env vars / secrets baked into the sandbox AT CREATION so the agent's
# in-sandbox commands have what they need (a git token for `git push`, a
# vendor CLI's API key, a registry login). These are the SANDBOXED
# command's env — separate from the agent process env and the model API
# key. Implemented for the daytona backend today (injected into the
# Daytona create call); other backends adopt the same knobs as they wire
# it in. All optional; unset → nothing injected (unchanged behavior).
#
# Static literals (KEY=VALUE,… or a JSON object for values with commas):
# ADK_CC_SANDBOX_ENV=TZ=UTC,LANG=C.UTF-8
# Copy named vars from the AGENT process env into the sandbox:
# ADK_CC_SANDBOX_ENV_PASSTHROUGH=GITHUB_TOKEN,HF_TOKEN
# Per-tenant secrets — ENV_NAME=credential_key; the value is resolved from
# the CredentialProvider for the session's tenant (production multi-tenant;
# requires a provider — in static-token/dev mode these entries are skipped):
# ADK_CC_SANDBOX_ENV_CREDENTIALS=GITHUB_TOKEN=gh_pat,NPM_TOKEN=npm_token


# --- Docker sandbox (when ADK_CC_SANDBOX_BACKEND=docker) ---

# Connection target — pick one shape:
#   unix:///var/run/docker.sock     (local socket, agent co-located)
#   tcp://sandbox.internal:2375     (plain TCP, trusted internal network)
#   tcp://sandbox.internal:2376     (TLS TCP — also set the three CERT vars)
# ADK_CC_DOCKER_HOST=tcp://sandbox.internal:2375

# Optional mTLS. If all three are set, mutual TLS is used. Plain
# (or unix-socket) connection if any is unset.
# ADK_CC_DOCKER_CA_CERT=/etc/adk-cc/docker-tls/ca.pem
# ADK_CC_DOCKER_CLIENT_CERT=/etc/adk-cc/docker-tls/cert.pem
# ADK_CC_DOCKER_CLIENT_KEY=/etc/adk-cc/docker-tls/key.pem

# Container spawn config (all optional)
# ADK_CC_SANDBOX_IMAGE=adk-cc-sandbox:latest
# ADK_CC_SANDBOX_MEM_LIMIT=4g
# ADK_CC_SANDBOX_CPU_QUOTA=100000        # microseconds per 100ms; 100000 = 1 CPU
# ADK_CC_SANDBOX_PIDS_LIMIT=256


# --- Sandbox service backend (when ADK_CC_SANDBOX_BACKEND=sandbox_service) ---
# Delegates exec / file IO to an external REST sandbox service —
# https://github.com/JISUlicious/sandboxing (or any compatible service
# exposing the same /v1/sessions API). adk-cc talks to the REST surface;
# the service's MCP endpoint at /mcp is for direct LLM clients (Claude
# Code/Desktop) and is not used by adk-cc.
#
# Persistence ceiling: per-session volumes are wiped after the service's
# `Limits.hard_destroy_ttl_s` (default 24h). adk-cc's per-user persistent
# home assumption only holds within that window — push long-lived state
# elsewhere or raise the TTL via ADK_CC_SANDBOX_SERVICE_HARD_DESTROY_TTL_S.
#
# Multi-tenancy: upstream PRs #10/#11 added a tenant management API and
# scoped per-tenant tokens. adk-cc supports two modes:
#   1. Dev / single-tenant: set ADK_CC_SANDBOX_SERVICE_SHARED_TOKEN. All
#      adk-cc tenants share the bootstrap token; per-adk-cc-tenant
#      separation comes from adk-cc's audit / workspace paths only.
#   2. Production multi-tenant: leave SHARED_TOKEN unset and store one
#      service-issued scoped token per adk-cc tenant in the credential
#      provider (the existing ADK_CC_CREDENTIAL_PROVIDER store). Operator
#      passes the provider into TenancyPlugin's backend_factory; backend
#      resolves the token by `(tenant_id, ADK_CC_SANDBOX_SERVICE_TOKEN_KEY)`
#      at session bring-up. Token rotation is mechanical: ops calls the
#      upstream rotate endpoint and updates the credential store; the
#      5-minute grace window covers in-flight sessions.
# ADK_CC_SANDBOX_SERVICE_URL=https://sandbox.internal:8443
# ADK_CC_SANDBOX_SERVICE_VERIFY_TLS=1                     # 0 to skip cert check (dev only)
# ADK_CC_SANDBOX_SERVICE_SHARED_TOKEN=<bootstrap bearer>  # mode 1 only
# ADK_CC_SANDBOX_SERVICE_TOKEN_KEY=sandbox_service_token  # default key in credential provider

# Optional Limits overrides (sent on POST /v1/sessions; subject to upstream
# tenant-max policy). Defaults shown for reference.
# ADK_CC_SANDBOX_SERVICE_VCPU=2
# ADK_CC_SANDBOX_SERVICE_MEMORY_GIB=2
# ADK_CC_SANDBOX_SERVICE_WORKSPACE_GIB=1
# ADK_CC_SANDBOX_SERVICE_EXEC_TIMEOUT_S=60
# ADK_CC_SANDBOX_SERVICE_HARD_DESTROY_TTL_S=604800        # 7d (default 86400)


# --- Daytona backend (when ADK_CC_SANDBOX_BACKEND=daytona) ---
# Delegates exec / file IO to a self-hosted Daytona compute plane.
# Daytona splits operations between two services, both reachable from
# external clients on a stock self-hosted deployment:
#   1. Control plane (port 3000): sandbox lifecycle — create/start/
#      stop/delete, snapshots, organizations, runners. NestJS service.
#   2. Toolbox proxy (port 4000): per-operation exec / file IO,
#      dispatched by URL path. Dedicated Go service; doesn't proxy
#      through the control plane (the [DEPRECATED] /api/toolbox/*
#      routes on the control plane do, and shouldn't be used for new
#      clients — every byte gets relayed through NestJS).
#
# Canonical toolbox URL shape for external clients (confirmed against
# stock docker-compose v0.176.0):
#   POST http://<proxy-host>:4000/toolbox/<sandboxId>/<route>
# where <route> is the in-sandbox toolbox path WITHOUT a leading
# /toolbox/ segment (e.g. `process/execute`, `files/upload`,
# `files/download`, `process/session`). One Bearer header, dispatched
# purely by URL path — the proxy doesn't inspect the Host header for
# these routes, so the `proxy.localhost` literal returned by
# `GET /api/sandbox/{id}/toolbox-proxy-url` is cosmetic; substitute
# the externally-reachable host IP.
#
# Auth: control plane uses HTTP Bearer. Generate an API key in the
# Daytona dashboard (`<control-plane>/dashboard`) and put it below.
# Single-tenant: shared bootstrap key for the whole adk-cc deployment.
# Multi-tenant: leave _API_KEY unset and pass per-tenant tokens via the
# credential provider (same shape as sandbox_service's token resolution).

# Control-plane base URL (no trailing slash). Used for sandbox
# lifecycle and snapshot management.
# ADK_CC_DAYTONA_API_URL=http://172.30.1.33:3000

# Toolbox proxy base URL (no trailing slash). Used for exec and file
# operations. Stock docker-compose publishes this on port 4000 of the
# same host as the control plane; defaults to the API host with port
# 4000 substituted when unset.
# ADK_CC_DAYTONA_PROXY_URL=http://172.30.1.33:4000

# Bearer API key (required when backend=daytona). Generate at
# <ADK_CC_DAYTONA_API_URL>/dashboard or via `POST /api/api-keys`.
# The same key authenticates against BOTH the control plane and the
# toolbox proxy. Never commit to git.
# ADK_CC_DAYTONA_API_KEY=dtn_replace_me

# Snapshot ID/name the sandbox is created from. If omitted, Daytona
# falls back to its default (`daytonaio/sandbox:0.5.0-slim` at the time
# of writing — confirm via `GET /api/config`). Operators typically
# pre-bake a snapshot with Python + uv + agent deps so cold-start is
# fast; see docs/04-deployment-sandbox.md Path D for the recipe.
# ADK_CC_DAYTONA_SNAPSHOT=adk-cc-base:latest

# Resources (cpu/memory/disk) are NOT exposed as env vars in v1.
# Daytona rejects resource fields alongside a snapshot
# (sandbox.controller.ts:304-306 — "Cannot specify Sandbox resources
# when using a snapshot"), and v1 always routes through snapshots.
# Custom resource sizing goes through a `buildInfo` build in v2.
# Bake the resource profile into your snapshot for now.

# How long to wait for the sandbox to reach state=started during
# ensure_workspace(). Polled with exponential backoff (0.5s → 5s
# cap). Daytona cold-starts can take 30-60s on first-pull;
# warm-cached snapshots come up in 1-2s. Default: 120.
# ADK_CC_DAYTONA_START_TIMEOUT_S=120

# Per-request HTTP timeout for control-plane and toolbox-proxy calls
# (excludes the polling deadline above). Default: 30.
# ADK_CC_DAYTONA_REQUEST_TIMEOUT_S=30

# Auto-stop after N minutes of inactivity (0 disables). Daytona pauses
# the sandbox; resume cost is the snapshot-restore latency, usually
# seconds. Default: 15.
# ADK_CC_DAYTONA_AUTOSTOP_MIN=15

# Auto-delete after N minutes (negative disables). Reclaims storage
# on long-abandoned sandboxes. Default: 1440 (24h).
# ADK_CC_DAYTONA_AUTODELETE_MIN=1440

# On session close (`close()` callback fires when the agent's session
# ends), call DELETE on the sandbox instead of STOP. Stop preserves the
# workspace for resume; delete reclaims storage immediately. Default:
# unset (stop). Set to 1 for ephemeral CI-style usage.
# ADK_CC_DAYTONA_DELETE_ON_CLOSE=1

# Per-tenant credential provider key (production multi-tenant). When
# ADK_CC_DAYTONA_API_KEY is unset and a CredentialProvider is wired
# into the runtime, DaytonaBackend resolves the per-tenant token via
# credentials.get(tenant_id, key=<this>). Default: "daytona_api_key".
# ADK_CC_DAYTONA_CREDENTIAL_KEY=daytona_api_key

# Workspace path INSIDE the sandbox. The Daytona toolbox treats this
# as cwd for exec and as the path root for file ops. Defaults to
# Daytona's default user home (`/home/daytona`).
#
# Recommended: `/workspace` — a neutral path that doesn't reveal the
# underlying sandbox tool in anything the agent surfaces to end users
# (`pwd`, tracebacks, shell output). The shipped Dockerfile.daytona-
# snapshot creates + chowns /workspace for the sandbox user, so it's
# writable out of the box when you build from that snapshot.
#
# MUST be writable by the sandbox user (`daytona`). Any custom top-level
# dir you point this at needs the same `mkdir -p && chown daytona:daytona`
# treatment in your snapshot, or file ops will 400.
# ADK_CC_DAYTONA_WORKSPACE_PATH=/workspace

# --- TLS verification --------------------------------------------------
# By default, the backend uses httpx + certifi to verify the Daytona
# control plane / toolbox proxy certificates. Two escape hatches:
#
# 1. Private CA. Point at a PEM bundle. Wins over VERIFY_SSL=0 below.
# ADK_CC_DAYTONA_CA_BUNDLE=/etc/ssl/certs/daytona-ca.pem
#
# 2. Disable verify entirely. Use ONLY for self-signed dev/test
#    deployments on a trusted network. Production should never run
#    with this set.
# ADK_CC_DAYTONA_VERIFY_SSL=0


# =============================================================================
# Logging
# =============================================================================
# Stdlib `logging` configuration for the `adk_cc` logger tree. The handler
# attaches to the `adk_cc` parent logger so every submodule's
# `logging.getLogger(__name__)` cascades through it. See
# adk_cc/logging_setup.py for the full design.

# Level for the adk_cc logger. Standard names: DEBUG, INFO, WARNING,
# ERROR, CRITICAL (case-insensitive). Unknown values silently fall back
# to INFO. Default: INFO.
#
# Bump to DEBUG to surface the per-decision logs that landed in the
# debug-logging PR: every permission `decide()` outcome with matched
# rule + reason, every confirmation request/resume, every state write
# (permission_mode flips, allow-rule writes incl. literal + broadened
# rule_contents). Useful when an Allow always rule isn't firing for a
# similar command, or when tracing the confirmation round-trip.
# ADK_CC_LOG_LEVEL=DEBUG

# Stderr format. `text` (default) emits `LEVEL adk_cc.module: message`
# for human scanning. `json` emits one JSON object per line — fields
# `ts`, `level`, `logger`, `message`, plus any `extra=` kwargs from the
# callsite as top-level keys. Internal LogRecord noise (pathname,
# process, thread, ...) is stripped. Right for piping to a log
# aggregator (Loki, Datadog, CloudWatch).
# ADK_CC_LOG_FORMAT=json

# Raw model request/response trace. When set to 1, the
# `ModelIOTracePlugin` dumps every LLM turn's full `LlmRequest`
# (chat history + tool schemas + config) and `LlmResponse` (model
# output + error fields) at DEBUG level AND as `model_request` /
# `model_response` audit events when an audit sink is configured.
#
# Off by default — payloads are large (multi-MB per turn with full
# tool schemas + history is normal) and would balloon stderr / audit
# JSONL disk budgets. Flip on for the debugging session that needs to
# answer "what exactly did we send" or "why did the model emit this".
# ADK_CC_LOG_MODEL_IO=1

# Per-payload byte cap for the model I/O trace. Truncated payloads
# get a `"truncated": true` marker and the original byte count so
# operators know to bump this or look elsewhere. Default: 50000.
# ADK_CC_LOG_MODEL_IO_MAX_BYTES=200000


# =============================================================================
# Audit (Stage D)
# =============================================================================
# Structured durable trail of agent activity, written as JSONL. Schema
# is versioned via the `event` field; consumers should switch on it.
# Operators without audit configured get zero overhead — the helpers
# are silent no-ops when no AuditPlugin is constructed.
#
# Event types:
#   tool_call_attempt    — every tool call attempt (incl. denied)
#   tool_call_result     — after execution (only fires on executed)
#   tool_call_error      — execution raised
#   permission_decision  — decide() outcome (behavior + matched_rule + reason + mode)
#   state_mutation       — permission_mode_change OR allow_rule_added
#                          (incl. literal + broadened rule_contents)
#   confirmation_resume  — user response received and applied
#                          (chose_id + confirmed flag)
#   model_request        — full LlmRequest dump (gated by ADK_CC_LOG_MODEL_IO)
#   model_response       — full LlmResponse dump (gated by ADK_CC_LOG_MODEL_IO,
#                          partial chunks skipped)
#   compaction_triggered — before LlmEventSummarizer fires
#                          (model_id, event_count, last_event_ts)
#   compaction_success   — summarizer returned a non-None event
#                          (model_id, event_count, summary_bytes, elapsed_ms)
#   project_context_loaded — CLAUDE.md / CONTEXT.md auto-loaded into
#                          system_instruction (first load + on every
#                          file mtime drift)
#   compaction_failure   — None return (reason=empty_summary) or exception
#                          (reason=exception, error_type, error_message)

# JSONL log destination. Default: ~/.adk-cc/audit.jsonl
# ADK_CC_AUDIT_LOG=/var/log/adk-cc/audit.jsonl


# =============================================================================
# Project memory (CLAUDE.md / .adk-cc/CONTEXT.md)
# =============================================================================
# ProjectContextPlugin auto-loads context files into every turn's
# system_instruction. Mirrors upstream Claude Code's CLAUDE.md
# behavior — drop a markdown file at the project root and the model
# picks up conventions, command preferences, and codebase notes
# without operator prompt-wrangling.
#
# Source precedence (top of system_instruction = first):
#   1. Project (walks up from cwd):
#        - ONE OF (per dir, priority order): CLAUDE.md, AGENTS.md
#          (vendor-neutral fallback when CLAUDE.md is absent)
#        - PLUS: .adk-cc/CONTEXT.md (adk-cc-namespaced; loads
#          alongside whichever CLAUDE.md/AGENTS.md wins)
#   2. Tenant (multi-tenant only): <tenant_workspace>/CONTEXT.md,
#                                  <tenant_workspace>/<user_id>/CONTEXT.md
#   3. User:
#        - ~/.adk-cc/CONTEXT.md (always)
#        - ONE OF: ~/.claude/CLAUDE.md, ~/.agents/AGENTS.md
#   4. Operator extras (below).
#
# Pick-one rule: when both CLAUDE.md and AGENTS.md exist in the same
# directory, CLAUDE.md wins — projects already using the upstream
# convention see no behavior change; AGENTS.md is a strict fallback.
#
# Hot reload: files are re-read when on-disk mtime drifts; no
# restart needed to pick up a CLAUDE.md edit. Audit event
# `project_context_loaded` fires on first load + on each mtime
# change.

# Set to 1 to disable the plugin entirely. Plugin construction is
# still cheap; this just no-ops before_model_callback.
# ADK_CC_DISABLE_PROJECT_CONTEXT=1

# Comma-separated ABSOLUTE paths appended to the discovery list.
# Useful when context lives outside cwd / home (e.g. a shared
# /etc/adk-cc/CONTEXT.md owned by ops).
# ADK_CC_CONTEXT_FILES=/etc/adk-cc/CONTEXT.md,/srv/conventions.md

# Per-file byte cap. Files larger than this are loaded truncated
# with a "(... truncated ...)" marker. Total system_instruction
# growth = sum of all loaded files (after truncation). Default 50000.
# ADK_CC_CONTEXT_MAX_BYTES=100000


# =============================================================================
# Web fetch (Stage E)
# =============================================================================

# Extra preapproved hosts (comma-separated). Appended to the default list.
# ADK_CC_WEB_FETCH_HOSTS=docs.mycompany.com,internal-wiki.mycompany.com


# =============================================================================
# Skills (Stage E)
# =============================================================================

# Single-tenant skills: directory of skill folders to auto-load at
# boot. Discovery aggregates these sources in priority order
# (first-found name wins across all sources):
#
#   1. ADK_CC_SKILLS_DIR (operator explicit — when set; below).
#   2. Project walk-up from cwd. Per directory, ONE OF (priority
#      order): `.adk-cc/skills/`, `.claude/skills/`. Walked up to
#      home / filesystem root. Skipped entirely when
#      ADK_CC_DISABLE_PROJECT_SKILLS=1.
#   3. Install fallback `<install>/adk_cc/skills/` if present.
#
# Skill scripts (run_skill_script) execute via
# SandboxBackedCodeExecutor by default — same sandbox boundary as
# run_bash. With ADK_CC_SANDBOX_BACKEND=noop, scripts run on the
# host (dev only); with docker / sandbox_service, scripts run inside
# the session's container.
# ADK_CC_SKILLS_DIR=/etc/adk-cc/skills

# Disable the project walk-up. Useful when an operator wants the
# tool surface to ONLY come from ADK_CC_SKILLS_DIR + the install
# fallback — e.g. CI environments where cwd is incidental.
# ADK_CC_DISABLE_PROJECT_SKILLS=1

# Multi-tenant skills: per-tenant skill root. Setting this attaches the
# TenantSkillToolset to the coordinator. Skill scripts run inside the
# active session's sandbox via SandboxBackedCodeExecutor. Skills land at
# <root>/<tenant_id>/<skill_name>/. The admin upload route writes here.
# ADK_CC_TENANT_SKILLS_DIR=/var/lib/adk-cc/skills

# --- Skill resource loading: bounds + guards ---
# load_skill_resource returns BOUNDED, paginated slices (like read_file)
# instead of dumping whole files into context. Defaults are sensible; tune
# only if needed.
# Default lines returned per load_skill_resource call (model can override
# with `limit`, capped at the max below):
# ADK_CC_SKILL_RESOURCE_DEFAULT_LINES=200
# Hard cap on lines per call:
# ADK_CC_SKILL_RESOURCE_MAX_LINES=400
# Cap on SKILL.md instructions injected by load_skill (chars):
# ADK_CC_SKILL_INSTRUCTIONS_MAX_CHARS=60000
# References/assets larger than this (bytes) are kept OUT of memory and served
# on demand (bounded) from disk — bounds RAM for skills with large bundles
# (text only; binary assets stay in memory so they remain reachable):
# ADK_CC_SKILL_FILE_MAX_BYTES=262144
# Hard cap (bytes) on a single disk read — for the load_skill_resource disk
# fallback and search_skill_resource. Files larger than this are skipped/not
# inlined rather than read whole into RAM. Default 4 MiB:
# ADK_CC_SKILL_RESOURCE_READ_MAX_BYTES=4194304
# Phase-2 guards (OFF by default; turn the whole group on with =1):
#   - refuse run_skill_script under the noop backend (host exec)
#   - wrap model-bound skill content in untrusted-content delimiters
# ADK_CC_SKILL_GUARDS=1
# Override the noop-backend script refusal (acknowledge host execution):
# ADK_CC_SKILL_SCRIPTS_ACK_HOST_EXEC=1


# =============================================================================
# Context guardrail
# =============================================================================
# Two-layer protection against the LLM context window filling up:
#   1. ADK's EventsCompactionConfig (post-invocation compaction via
#      LlmEventSummarizer) — the primary defense.
#   2. ContextGuardPlugin (pre-flight WARN log + fail-soft REJECT) — the
#      safety net for turns that jump past the window in one step.
# See docs/05-production-deployment.md for tuning guidance.

# --- Primary: ADK compaction ---
# Operator picks token-threshold OR sliding-window OR both.

# Token-threshold trigger (recommended). Fires post-invocation when
# prompt_token_count ≥ TOKEN_THRESHOLD; keeps the last EVENT_RETENTION
# raw events un-compacted. Both must be set together.
# ADK_CC_COMPACTION_TOKEN_THRESHOLD=70000
# ADK_CC_COMPACTION_EVENT_RETENTION=10

# Sliding-window trigger (alternative, fixed cadence — predictable
# latency vs reactive token-threshold). Compacts every INTERVAL user
# invocations with OVERLAP-invocation overlap between summaries.
# ADK_CC_COMPACTION_INTERVAL=10
# ADK_CC_COMPACTION_OVERLAP=2

# Optional dedicated compaction model. Falls back to the main agent
# model. Useful when the main model is expensive and a small model is
# enough for "summarize the conversation". Independent endpoint allowed.
# ADK_CC_COMPACTION_MODEL=openai/gpt-4o-mini
# ADK_CC_COMPACTION_API_BASE=                # defaults to ADK_CC_API_BASE
# ADK_CC_COMPACTION_API_KEY=                 # defaults to ADK_CC_API_KEY

# Compaction timeout (seconds). Compaction runs as a request
# preprocessor BEFORE each LLM call (ADK's CompactionRequestProcessor)
# — it's awaited synchronously, so a stuck summarizer hangs the user's
# turn. With this timeout, `asyncio.wait_for` interrupts at the cap;
# the wrapper emits `compaction_failure` (reason=timeout), returns
# None, and the turn proceeds with uncompacted history. Exceptions
# also degrade to None (same audit event with reason=exception).
#
# Default: 30. Set to 0 to disable the timeout entirely (preserves
# pre-PR-22 behavior of indefinite wait). Negative values clamp to 0.
# ADK_CC_COMPACTION_TIMEOUT_S=30

# --- Pre-flight guardrail (ContextGuardPlugin) ---
# Plugin is always attached. When MAX_CONTEXT_TOKENS is unset it
# no-ops; otherwise it logs WARN and returns a friendly REJECT message
# for the turn that would otherwise overflow the window.
# ADK_CC_MAX_CONTEXT_TOKENS=100000             # the main model's window
# ADK_CC_CONTEXT_WARN_TOKENS=                  # default: 75% of MAX
# ADK_CC_CONTEXT_REJECT_TOKENS=                # default: 95% of MAX

# Tuning relationship:
#   COMPACTION_TOKEN_THRESHOLD < CONTEXT_WARN_TOKENS < CONTEXT_REJECT_TOKENS < MAX
#   Headroom = MAX − COMPACTION_TOKEN_THRESHOLD must accommodate the largest
#   single-turn token growth (e.g. one big tool result).


# =============================================================================
# Tasks (Stage F)
# =============================================================================

# Where the JsonFileTaskStorage writes <tenant>/<session>/<id>.json files.
# Default: ~/.adk-cc/tasks/
# ADK_CC_TASKS_DIR=/var/lib/adk-cc/tasks

# Task-reminder plugin. Periodically injects a system-reminder listing
# the session's open tasks so the model keeps the list current and closes
# finished items. The task TOOLS work regardless of this; the switch only
# governs the nudge.
#
# Master on/off. Default on; set 0 to disable the reminder entirely.
# ADK_CC_TASK_REMINDER=0
#
# Trigger thresholds. The reminder fires when:
#   (turns since last task_create/task_update) >= threshold
#   AND (turns since last reminder) >= TURNS_BETWEEN
# `threshold` is TURNS_SINCE_WRITE normally, or OPEN_TURNS when an
# in_progress task is open (completion-aware: nudges the model to close
# it sooner rather than after 10 idle turns). Set OPEN_TURNS >=
# TURNS_SINCE_WRITE to disable the aggressive path.
# ADK_CC_TASK_REMINDER_TURNS_SINCE_WRITE=10
# ADK_CC_TASK_REMINDER_TURNS_BETWEEN=10
# ADK_CC_TASK_REMINDER_OPEN_TURNS=3
#
# Cooldown between reminders while an in_progress task is open. Lower than
# TURNS_BETWEEN so the "close it out" nudge keeps firing as the agent winds
# down (the 10-turn cooldown otherwise silences it right at the finish).
# Set >= TURNS_BETWEEN to disable. Also: a new user turn that opens with any
# task still open always fires once (bypasses cooldown) to confront tasks
# left dangling from the previous turn.
# ADK_CC_TASK_REMINDER_OPEN_BETWEEN=2
#
# Debug: log the fire decision (agent, fresh_turn, turn counts, open-task
# count, fire/skip) to stderr on every model call. Off by default; handy
# for confirming the reminder actually fires (and reads the right task
# bucket) in a live run.
# ADK_CC_TASK_REMINDER_DEBUG=1


# =============================================================================
# Per-tenant resources (MCP servers, credentials)
# =============================================================================

# Root directory for the tenant resource registry. Setting this enables
# the per-tenant MCP toolset on the coordinator. Files land at
# <root>/<tenant_id>/mcp.json (filelock-protected JSON, atomic writes).
# ADK_CC_TENANT_REGISTRY_DIR=/var/lib/adk-cc/tenants

# Credential provider: memory (dev/tests; lost on restart) or encrypted_file.
# ADK_CC_CREDENTIAL_PROVIDER=encrypted_file

# Encrypted-file provider config (required when PROVIDER=encrypted_file):
#   ADK_CC_CREDENTIAL_KEY: Fernet key. Generate with:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   ADK_CC_CREDENTIAL_STORE_DIR: where the encrypted blobs live.
# ADK_CC_CREDENTIAL_KEY=<paste-generated-key-here>
# ADK_CC_CREDENTIAL_STORE_DIR=/var/lib/adk-cc/credentials


# =============================================================================
# Service / multi-tenant deployment (Stage G)
# =============================================================================

# Required when running `uvicorn adk_cc.service.server:make_app --factory`.
# Path to the AGENTS_DIR — the `agents/` directory that holds the agent
# package(s). ADK discovers every immediate subdir of this path as an
# app, so it must contain ONLY agents (not the repo's web/ docs/ tests/).
# ADK_CC_AGENTS_DIR=/srv/adk-cc/agents

# Session storage DSN. None → in-memory (dev only).
# Examples:
#   sqlite:///./adk-cc.db
#   postgresql://user:pass@host:5432/adk_cc
# ADK_CC_SESSION_DSN=postgresql://user:pass@host:5432/adk_cc

# Artifact storage URI. Where files saved via the `save_as_artifact`
# tool live. None → ADK's default in-memory store (dev only — wiped
# on restart). For persistence, point at a local dir, GCS bucket, or
# an S3 / S3-compatible bucket:
#   ADK_CC_ARTIFACT_STORAGE_URI=/var/lib/adk-cc/artifacts
#   ADK_CC_ARTIFACT_STORAGE_URI=gs://my-bucket/adk-cc/artifacts
#   ADK_CC_ARTIFACT_STORAGE_URI=s3://my-bucket/adk-cc/artifacts
# ADK_CC_ARTIFACT_STORAGE_URI=/var/lib/adk-cc/artifacts

# --- S3 / S3-compatible artifacts (when the URI is s3://…) ---
# Requires the `s3` extra: `pip install 'adk-cc[s3]'` (adds boto3).
# The s3:// URI is just `s3://<bucket>/<optional-prefix>`; connection
# details come from the environment:
#   - Credentials: boto3's default chain — AWS_ACCESS_KEY_ID +
#     AWS_SECRET_ACCESS_KEY, a shared profile, or an instance/IRSA role.
#   - Region: AWS_REGION (or AWS_DEFAULT_REGION).
#   - Endpoint: set ADK_CC_S3_ENDPOINT_URL for S3-compatible stores
#     (MinIO / Cloudflare R2 / Wasabi / Backblaze B2 / Ceph RGW /
#     DigitalOcean Spaces). Omit for AWS S3.
# Example (MinIO):
#   ADK_CC_ARTIFACT_STORAGE_URI=s3://adk-cc/artifacts
#   ADK_CC_S3_ENDPOINT_URL=https://minio.internal:9000
#   AWS_ACCESS_KEY_ID=…
#   AWS_SECRET_ACCESS_KEY=…
#   AWS_REGION=us-east-1
# ADK_CC_S3_ENDPOINT_URL=https://minio.internal:9000

# --- Static MCP servers (single-tenant / dev) ----------------------------
# Two ways to attach MCP servers to the coordinator at boot, additive:
#
# (1) A SINGLE server via env vars.
#   ADK_CC_MCP_SERVER       : stdio command (e.g. "python server.py"), or the
#                             URL when TRANSPORT is sse/http. Unset = no
#                             single static server.
#   ADK_CC_MCP_SERVER_NAME  : logical name → tool prefix mcp__<name>__ (default "mcp")
#   ADK_CC_MCP_TRANSPORT    : stdio | sse | http (default stdio)
#   ADK_CC_MCP_SAVE_RESOURCES_AS_ARTIFACTS : 1 to add a save_resource_as_artifact tool
#   ADK_CC_MCP_USE_RESOURCES : 1 to add load_mcp_resource + inject the resource catalog
# ADK_CC_MCP_SERVER=python tests/fixtures/csv_mcp_server.py
# ADK_CC_MCP_SERVER_NAME=csv
# ADK_CC_MCP_TRANSPORT=stdio
# ADK_CC_MCP_SAVE_RESOURCES_AS_ARTIFACTS=1
# ADK_CC_MCP_USE_RESOURCES=1
#
# (2) MULTIPLE servers via a JSON file (path here). A JSON ARRAY of server
# configs — same schema as the per-tenant registry (server_name, transport,
# url, credential_key?, tool_filter?, require_confirmation?,
# save_resources_as_artifacts?, use_mcp_resources?). Loaded at boot; each
# becomes mcp__<server_name>__*. Fault-isolated: a bad file, or one bad
# entry, is logged and skipped — boot is never blocked. Works ALONGSIDE the
# single ADK_CC_MCP_SERVER above; a file entry whose server_name collides
# with it is dropped (prefixes would clash).
#
# Static auth: `credential_key`, when set, names an ENV VAR holding the
# bearer token (there is no credential store at boot — that's the tenant
# path). Missing env var → the server still wires, unauthenticated, with a
# warning. stdio servers ignore auth.
#
#   Example /etc/adk-cc/mcp.json:
#   [
#     {"server_name":"github","transport":"http",
#      "url":"https://api.github.com/mcp",
#      "credential_key":"GITHUB_MCP_TOKEN","tool_filter":["list_repos"]},
#     {"server_name":"csv","transport":"stdio",
#      "url":"python tests/fixtures/csv_mcp_server.py"}
#   ]
# ADK_CC_MCP_SERVERS_FILE=/etc/adk-cc/mcp.json
#
# For PER-TENANT MCP servers (different per user/tenant, hot-reloaded, admin
# API), use the tenant registry instead — see ADK_CC_TENANT_REGISTRY_DIR above.

# --- MCP export auto-persist (McpExportArtifactPlugin) ---
# File-bearing content returned by `mcp__*` tool calls (an embedded
# resource, or a resource_link to an export) is auto-saved to the artifact
# store, so MCP export tools yield a downloadable artifact with no agent
# decision. Embedded inline bytes are stripped from the result once saved
# (kept out of the model's context). ENABLED BY DEFAULT — set to 0 to
# disable (then the per-call cost is a single attribute check).
# ADK_CC_MCP_AUTOSAVE_EXPORTS=0
# Only auto-save content whose annotations mark audience "user" (i.e. meant
# for the human to download, not the model's own working blobs). Default on;
# set 0 to auto-save every embedded/linked resource regardless of audience.
# ADK_CC_MCP_AUTOSAVE_AUDIENCE_USER_ONLY=1

# YAML rules/policy file. Holds two INDEPENDENT blocks:
#   rules:    → PermissionPlugin — confirmation + a subject-blind guardrail
#               deny-list ("is this op forbidden for anyone?").
#   policies: → AuthzPlugin — subject-aware authorization ("may THIS subject
#               do it?"); only enforced when ADK_CC_AUTHZ=1 (see Authorization).
# Format documented in adk_cc/config/settings_loader.py.
# ADK_CC_PERMISSIONS_YAML=/etc/adk-cc/permissions.yaml

# Per-tenant tool-call rate cap. Default: 120
# ADK_CC_QUOTA_PER_MINUTE=120

# Auth — pick ONE of the two stock extractors, or skip both and use a
# custom AuthExtractor by writing your own factory around build_fastapi_app.

# Production JWT extractor. Required field: JWKS_URL.
# Validates signature against JWKS (cached with TTL); checks exp/nbf;
# matches iss/aud if set; maps user_claim/tenant_claim from JWT claims.
# ADK_CC_JWT_JWKS_URL=https://idp.example.com/.well-known/jwks.json
# ADK_CC_JWT_ISSUER=https://idp.example.com
# ADK_CC_JWT_AUDIENCE=adk-cc
# ADK_CC_JWT_USER_CLAIM=sub
# ADK_CC_JWT_TENANT_CLAIM=tenant
# Claims carrying the subject's roles/scopes (consumed by authZ; see below).
# ADK_CC_JWT_ROLES_CLAIM=roles
# ADK_CC_JWT_SCOPES_CLAIM=scope

# Dev BearerTokenExtractor — static token map.
# Format: token=user:tenant,token2=user2:tenant2
# An optional third `:roles` segment carries |-delimited roles for authZ
# (scopes aren't settable via the dev token map — use JWT for scopes):
#   token=user:tenant:role1|role2
# ADK_CC_AUTH_TOKENS=alicetok=alice:acme,bobtok=bob:beta,supertok=super:acme:admin|deployer

# Dev-only no-auth escape. `make_app()` (the uvicorn --factory entry) fails
# closed when ADK_CC_AUTH_TOKENS is not set; setting this to 1 acknowledges
# you're running without auth. Do NOT set in production. Operators with a
# real JWT validator should use build_fastapi_app(auth_extractor=...)
# directly instead of make_app, and ignore this variable.
# ADK_CC_ALLOW_NO_AUTH=1

# Authorization (authZ — subject × action × resource gating).
# Hard, subject-aware authorization layered on authN. DEFAULT-OFF: unset →
# behavior unchanged (dev / single-tenant). Set to 1 to enable BOTH
# enforcement points: the tool-call gate (AuthzPlugin) and the REST gate
# that closes ADK's trust-the-path hole (without it an authenticated caller
# can read another user's sessions/artifacts by editing {user_id} in the
# URL). Subjects come from the principal's roles/scopes (above); policies
# from the `policies:` block of ADK_CC_PERMISSIONS_YAML. When ON the PDP is
# closed-world (unmatched ⇒ deny) — grant access via policies or rely on the
# owner / same-tenant baseline.
# ADK_CC_AUTHZ=1

# Session-service retry on stale-session errors. ADK's SqliteSessionService
# and DatabaseSessionService raise ValueError when the in-memory session
# ref's `last_update_time` is older than storage's — typically during HITL
# pause/resume because ADK's runner doesn't refresh the ref after each
# storage write. Setting this to 1 installs a wrapper that fetches a fresh
# session, syncs the timestamp, and retries the append once. Off by default;
# opt-in deliberate setting because retry-on-conflict has subtle semantics
# under truly concurrent writers (single retry, then surface the error).
# ADK_CC_SESSION_RETRY_ON_STALE=1


# =============================================================================
# Web UI (custom React chat under web/)
# =============================================================================

# Mount the built React chat UI (web/dist) at / on the same FastAPI
# process. Build it first: `npm --prefix web run build`. Off by default
# (API only). See docs/07-web-ui.md.
# ADK_CC_SERVE_UI=1

# Directory of the built UI bundle to serve. Default: <repo>/web/dist.
# Override only if you build the bundle somewhere else.
# ADK_CC_UI_DIST=/srv/adk-cc/web/dist

# Dev-only: the Vite dev server (`npm --prefix web run dev`, port 5173)
# proxies /run*, /apps, /list-apps, /api, /admin, /debug to this target.
# Default: http://127.0.0.1:8000. Not read by the server — consumed by
# vite.config.ts at dev time.
# ADK_CC_DEV_API=http://127.0.0.1:8000

# Interactive HTML artifact previews (BUILD-TIME flag, baked into the bundle
# by `npm run build` — NOT a server env var). Default OFF: HTML artifacts
# preview in a fully-locked iframe (sandbox="", no JS) — safe, but JS-built
# content (Plotly/Chart.js/frameworks) renders BLANK because its drawing code
# can't run. Set to 1 to flip the preview to sandbox="allow-scripts" so
# interactive artifacts render.
#   SECURITY TRADEOFF: this EXECUTES untrusted (model/user-generated) JS in
#   the user's browser. It can make network requests (CDN, or phone home with
#   anything in the artifact). It still CANNOT read the parent app's bearer
#   token / cookies / localStorage / DOM — `allow-same-origin` is hard-off, so
#   the frame stays on an opaque origin (verified by e2e). Opt in only if you
#   need interactive charts and accept running untrusted JS sandboxed.
# VITE_ADK_CC_HTML_PREVIEW_ALLOW_SCRIPTS=1


# =============================================================================
# Admin panel (manage MCP servers / skills / model endpoints at runtime)
# =============================================================================

# Enable the admin panel (default-OFF — unset changes nothing). When on:
#   - mounts the admin API (MCP servers, skills, credentials, model endpoints),
#   - serves the /admin page when the UI is also mounted (ADK_CC_SERVE_UI=1),
#   - wraps the model in a SelectableLlm so endpoints can be switched live,
#   - wires the agent's tenant MCP/skill toolsets against the admin store so
#     edits hot-reload (no restart).
# GLOBAL mode: all admin ops manage ONE deployment-wide config set, pinned to
# ADK_CC_GLOBAL_TENANT_ID. Requires an authenticated principal holding the
# admin role (ADK_CC_ADMIN_ROLE) — the page loads anonymously but every admin
# API call is gated.
# ADK_CC_ADMIN_PANEL=1

# Role the principal must hold to use the admin panel. Roles come from the
# JWT roles claim or the dev bearer token's 3rd segment
# (token=user:tenant:admin). Default: admin.
# ADK_CC_ADMIN_ROLE=admin

# The single tenant id the panel manages in global mode. Matches the tenant
# TenancyPlugin resolves for unauthenticated/single-tenant runs. Default: local.
# ADK_CC_GLOBAL_TENANT_ID=local

# Base dir for admin-managed data when the panel is on. Defaults the tenant
# registry / skills / model-endpoint files underneath it unless those vars
# are set explicitly. Default: <cwd>/.adk-cc/admin-data.
# ADK_CC_ADMIN_DATA_DIR=/var/lib/adk-cc/admin-data

# Where the model-endpoint registry (named endpoints + active pointer) is
# persisted. Defaulted under ADK_CC_ADMIN_DATA_DIR when the panel is on; set
# explicitly to relocate. The boot model (ADK_CC_MODEL/_API_BASE) is seeded
# as endpoint #1 ("default", or ADK_CC_MODEL_DEFAULT_NAME).
# ADK_CC_MODEL_REGISTRY_FILE=/var/lib/adk-cc/admin-data/model-endpoints.json
# ADK_CC_MODEL_DEFAULT_NAME=default
