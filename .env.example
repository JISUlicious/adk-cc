# adk-cc environment reference — GENERATED from agents/adk_cc/config/schema.py.
# Do not edit by hand; run `python -m adk_cc.config gen-env`. Copy to `.env`.
# Profile: all. Required vars are uncommented; everything else shows its default.

# ============================================================
# QUICKSTART — required + commonly set
# ============================================================

# --- Quickstart --------------------------------------------------------
#
# [Model]
# API key for your OpenAI-compatible model server.
ADK_CC_API_KEY=sk-replace-me
# OpenAI-compatible model server base URL.
# ADK_CC_API_BASE=http://localhost:18000/v1
# LiteLLM model id (openai/<id>, ollama_chat/<id>, anthropic/<id>, …).
# ADK_CC_MODEL=openai/Qwen3.6-35B-A3B-UD-MLX-4bit
# Throttle: max model-call starts per minute (paces all callers). Off by default.
# ADK_CC_MODEL_MAX_RPM=off
#
# [Context]
# Enable the context-guard ladder at this token budget. Unset = guard off.
# ADK_CC_MAX_CONTEXT_TOKENS=off
# Model for conversation summarization (falls back to the main model).
# ADK_CC_COMPACTION_MODEL=$ADK_CC_MODEL
#
# [Permissions]
# default | plan | acceptEdits | bypassPermissions | dontAsk. Dev default: bypassPermissions.
# ADK_CC_PERMISSION_MODE=bypassPermissions
# Path to a YAML of permission rules + authz policies.
# ADK_CC_PERMISSIONS_YAML=unset
#
# [Sandbox]
# noop | container | docker | e2b | sandbox_service | daytona | ssh. Default: noop (host exec).
# ADK_CC_SANDBOX_BACKEND=noop
# Static KEY=VALUE,… (or JSON) env baked into the sandbox for every command.
# ADK_CC_SANDBOX_ENV=unset
# Host env var names to copy into the sandbox (comma-separated).
# ADK_CC_SANDBOX_ENV_PASSTHROUGH=unset
#
# [Sandbox: Daytona]
# Daytona control-plane URL.
# ADK_CC_DAYTONA_API_URL=unset
# Daytona API key (single-tenant) or use a credential provider.
# ADK_CC_DAYTONA_API_KEY=unset
# Snapshot id/name to prewarm from (recommended).
# ADK_CC_DAYTONA_SNAPSHOT=unset
# Toolbox proxy base (derived :3000→:4000 if unset).
# ADK_CC_DAYTONA_PROXY_URL=derived
#
# [Sandbox: SSH]
# Remote host (alias or user@host) for the ssh backend env-factory path.
# ADK_CC_SSH_HOST=unset
# Absolute workspace path on the remote.
# ADK_CC_SSH_WORKSPACE_PATH=unset
#
# [Auth (web)]
# 1 = use the in-house email+password identity service.
# ADK_CC_AUTH_PASSWORD=0  (web-only)
# External IdP JWKS URL (Keycloak/…); presence selects the JWT auth path.
# ADK_CC_JWT_JWKS_URL=unset  (web-only)
# Enable the ABAC authorization plugin + /authz routes.
# ADK_CC_AUTHZ=0  (web-only)
# Mount the admin panel routes.
# ADK_CC_ADMIN_PANEL=0  (web-only)
# First-boot admin email (password mode). Inert after the first admin exists.
# ADK_CC_BOOTSTRAP_ADMIN_EMAIL=unset  (web-only)
# First-boot admin password (with EMAIL).
# ADK_CC_BOOTSTRAP_ADMIN_PASSWORD=unset  (web-only)
# Explicitly run with NO auth (fail-open). Desktop sets this; web dev only.
# ADK_CC_ALLOW_NO_AUTH=0
# Expected iss from the external IdP (unset = not verified).
# ADK_CC_JWT_ISSUER=unset  (web-only)
# Expected aud from the external IdP.
# ADK_CC_JWT_AUDIENCE=unset  (web-only)
# single | multi org model.
# ADK_CC_TENANCY_MODE=single  (web-only)
# Trust X-Forwarded-For for ratelimit/lockout IP (behind a proxy).
# ADK_CC_TRUST_PROXY=0  (web-only)
#
# [Deployment]
# Web/multi-tenant workspace anchor. Unset = CWD (dev zero-config).
# ADK_CC_WORKSPACE_ROOT=CWD
# Persistent session store DSN (postgres/sqlite). Unset = in-memory. Ignored in desktop.
# ADK_CC_SESSION_DSN=in-memory  (web-only)
# Artifact persistence URI (file://, gs://, s3://). Unset = in-memory.
# ADK_CC_ARTIFACT_STORAGE_URI=in-memory
# Agents root ADK discovers the agent package under (defaults to this package's agents/ dir).
# ADK_CC_AGENTS_DIR=<package>/agents
# Log verbosity (DEBUG/INFO/WARNING/…).
# ADK_CC_LOG_LEVEL=INFO
# Log format: text | json.
# ADK_CC_LOG_FORMAT=text
# Admin/tenant data root (when the admin panel is on).
# ADK_CC_ADMIN_DATA_DIR=<cwd>/.adk-cc/admin-data  (web-only)
# Tool/permission audit JSONL sink.
# ADK_CC_AUDIT_LOG=~/.adk-cc/audit.jsonl
#
# [Sandbox: Docker]
# Docker daemon (tcp://…, ssh://…).
# ADK_CC_DOCKER_HOST=unset
#
# [Sandbox: service]
# External sandbox REST service URL.
# ADK_CC_SANDBOX_SERVICE_URL=unset
# Shared bearer token (single-tenant) or use a credential provider.
# ADK_CC_SANDBOX_SERVICE_SHARED_TOKEN=unset
#
# [Credentials]
# memory | encrypted_file | none.
# ADK_CC_CREDENTIAL_PROVIDER=memory
# Secret store dir (required for encrypted_file).
# ADK_CC_CREDENTIAL_STORE_DIR=unset
# Fernet key for the encrypted secret store.
# ADK_CC_CREDENTIAL_KEY=unset
#
# [Memory & Wiki]
# Memory store dir.
# ADK_CC_MEMORY_ROOT=<workspace>/.memory
# Responsive consolidation trigger (unset = off).
# ADK_CC_MEMORY_CONSOLIDATE_THRESHOLD=off
# In-process periodic consolidation interval (≤0 = off).
# ADK_CC_MEMORY_CONSOLIDATE_INTERVAL_S=off
# Wiki store dir.
# ADK_CC_WIKI_ROOT=<workspace>/.wiki
#
# [MCP]
# JSON array of MCP servers to connect to (per-entry name/transport/filters/creds).
# ADK_CC_MCP_SERVERS_FILE=unset
#
# [Skills]
# Explicit skills root (shadows project/install skills).
# ADK_CC_SKILLS_DIR=unset


# ============================================================
# REFERENCE — advanced tuning (sane defaults; rarely changed)
# ============================================================

# --- Reference ---------------------------------------------------------
#
# [Model]
# Alternative to MAX_RPM: min seconds between model-call starts.
# ADK_CC_MODEL_MIN_INTERVAL_S=off
# Cap on model OUTPUT tokens/call (litellm max_tokens). 0 = uncapped; per-endpoint wins.
# ADK_CC_MAX_OUTPUT_TOKENS=8192
# Cap to escalate to after a mid-tool-call truncation (finish_reason=MAX_TOKENS). 0 disables.
# ADK_CC_MAX_OUTPUT_TOKENS_ESCALATED=32768
# Path to the live model-endpoint registry JSON (auto-defaulted when the admin panel is on).
# ADK_CC_MODEL_REGISTRY_FILE=auto
#
# [Context]
# Token threshold that triggers conversation compaction. Requires EVENT_RETENTION set too.
# ADK_CC_COMPACTION_TOKEN_THRESHOLD=off
# Events to keep when compacting (must be set together with TOKEN_THRESHOLD).
# ADK_CC_COMPACTION_EVENT_RETENTION=off
# Enable zero-cost tool-result eviction tier.
# ADK_CC_MICROCOMPACT=0
# API base for the compaction model (different provider).
# ADK_CC_COMPACTION_API_BASE=$ADK_CC_API_BASE
# API key for the compaction model.
# ADK_CC_COMPACTION_API_KEY=$ADK_CC_API_KEY
# Summarizer timeout seconds (0 = none).
# ADK_CC_COMPACTION_TIMEOUT_S=30
# Seed memory stores into the compaction summary (opt-in).
# ADK_CC_COMPACTION_SEED_MEMORY=0
# Token budget for seeded memory.
# ADK_CC_COMPACTION_SEED_BUDGET=300
# Compaction framing line; 0 disables, a string overrides the built-in.
# ADK_CC_COMPACTION_FRAME=built-in
# Compaction circuit-breaker failures before tripping (0 disables).
# ADK_CC_COMPACTION_BREAKER_THRESHOLD=3
# Circuit-breaker cooldown seconds.
# ADK_CC_COMPACTION_BREAKER_COOLDOWN_S=60
# Inline compaction prompt override.
# ADK_CC_COMPACTION_PROMPT=built-in template
# Path to a compaction prompt template.
# ADK_CC_COMPACTION_PROMPT_FILE=unset
# Event overlap when compacting.
# ADK_CC_COMPACTION_OVERLAP=2
# Event-count compaction interval (also an enable path).
# ADK_CC_COMPACTION_INTERVAL=10
# Per-file cap for CLAUDE.md/AGENTS.md/CONTEXT.md project-context injection.
# ADK_CC_CONTEXT_FILES_MAX_BYTES=50000
# Context-guard warn threshold (derived ~75% if unset).
# ADK_CC_CONTEXT_WARN_TOKENS=derived
# Output-headroom reserve for the context guard.
# ADK_CC_CONTEXT_RESERVE_TOKENS=0
# Context-guard hard-stop threshold (derived ~95% if unset).
# ADK_CC_CONTEXT_REJECT_TOKENS=derived
# Count tool payloads in context sizing (opt-in).
# ADK_CC_CONTEXT_COUNT_TOOL_PAYLOADS=0
# Extra absolute context files (comma-separated) layered on discovery.
# ADK_CC_CONTEXT_FILES=unset
# Microcompact size floor.
# ADK_CC_MICROCOMPACT_MIN_TOKENS=800
# Microcompact recency window.
# ADK_CC_MICROCOMPACT_KEEP_RECENT=4
#
# [Sandbox]
# Container image for container/docker backends.
# ADK_CC_SANDBOX_IMAGE=python:3.12-slim
# container backend: 1 = network on (dev), 0 = none.
# ADK_CC_SANDBOX_NETWORK=1
# 1 = fail closed: run_bash errors if the sandbox runtime is missing (no host fallback).
# ADK_CC_SANDBOX_REQUIRE=0
# Desktop sandbox mode: host | container (usually set via the UI).
# ADK_CC_SANDBOX_MODE=host  (desktop-only)
# Container runtime: auto | docker | podman.
# ADK_CC_SANDBOX_RUNTIME=auto
# Reap idle session containers after N seconds (0 = off).
# ADK_CC_SANDBOX_IDLE_TTL_S=0
# Container memory limit.
# ADK_CC_SANDBOX_MEM_LIMIT=4g
# Container CPU limit (container backend).
# ADK_CC_SANDBOX_CPUS=2
# Docker CPU quota (=1 CPU; docker backend).
# ADK_CC_SANDBOX_CPU_QUOTA=100000
# Container PID limit (docker backend defaults 256).
# ADK_CC_SANDBOX_PIDS_LIMIT=512
# Stream run_bash output to operator logs.
# ADK_CC_BASH_STREAM=0
# Ack host exec on prod-shaped paths (noop backend).
# ADK_CC_NOOP_ACK_HOST_EXEC=is_desktop()
# ENV_NAME=credential_key,… resolved per-tenant into the sandbox.
# ADK_CC_SANDBOX_ENV_CREDENTIALS=unset
#
# [Memory & Wiki]
# Enable the autonomous memory subsystem (recall + capture).
# ADK_CC_MEMORY=0
# Enable the explicit wiki tools.
# ADK_CC_WIKI=0
# Memory store URI (only file:// implemented — prefer MEMORY_ROOT).
# ADK_CC_MEMORY_STORE_URI=unset
# LLM consolidation unless set to 'deterministic'.
# ADK_CC_MEMORY_SYNTH=llm
# Capture memories after turns (0 = recall-only).
# ADK_CC_MEMORY_AUTOCAPTURE=1
# Identity-resolution model call (0 disables).
# ADK_CC_MEMORY_RESOLVE=1
# Verify resolution (sub-knob of RESOLVE).
# ADK_CC_MEMORY_RESOLVE_VERIFY=1
# Scheduler boot-settle delay (test hook).
# ADK_CC_MEMORY_CONSOLIDATE_DELAY_S=60
# Archive memories older than N days.
# ADK_CC_MEMORY_STALE_DAYS=90
# LLM compaction pass in the scheduler (0 disables).
# ADK_CC_MEMORY_COMPACT=1
# Episodic retention cap (0 = keep all).
# ADK_CC_MEMORY_EPISODIC_CAP=keep all
# Recall prompt budget.
# ADK_CC_MEMORY_RECALL_BUDGET_TOKENS=600
# Capture model-call timeout.
# ADK_CC_MEMORY_CAPTURE_TIMEOUT_S=30.0
# Wiki store URI (only file:// implemented — prefer WIKI_ROOT).
# ADK_CC_WIKI_STORE_URI=unset
# Corroborations before a wiki fact is trusted (admin API overrides).
# ADK_CC_WIKI_CORROBORATION_N=2
#
# [Deployment]
# Desktop data root (sessions, settings, secrets, checkpoints).
# ADK_CC_DESKTOP_DATA=~/.adk-cc-desktop  (desktop-only)
# Mount the SPA (set by the desktop app / UI deployments).
# ADK_CC_SERVE_UI=0
# Identity store dir (users/invites/keys/audit).
# ADK_CC_IDENTITY_DIR=.adk-cc/identity  (web-only)
# Per-tenant MCP registry dir.
# ADK_CC_TENANT_REGISTRY_DIR=<admin-data>/registry  (web-only)
# Per-tenant skills dir.
# ADK_CC_TENANT_SKILLS_DIR=<admin-data>/skills  (web-only)
# Desktop settings.env path override.
# ADK_CC_SETTINGS_FILE=unset  (desktop-only)
# Desktop-mode selector (set by the app, not users).
# ADK_CC_DESKTOP=0
# Central task storage override.
# ADK_CC_TASKS_DIR=<workspace>/.adk-cc/tasks
# S3 endpoint for s3:// artifacts (falls back to AWS_ENDPOINT_URL).
# ADK_CC_S3_ENDPOINT_URL=unset
# Built SPA dir to serve.
# ADK_CC_UI_DIST=<repo>/web/dist
# Experimental knowledge-graph endpoints.
# ADK_CC_KNOWLEDGE_UI=0
# Dump raw LLM request/response to DEBUG log.
# ADK_CC_LOG_MODEL_IO=0
# Truncation cap for LOG_MODEL_IO.
# ADK_CC_LOG_MODEL_IO_MAX_BYTES=50000
#
# [Behavior]
# Default-on repair of malformed tool-call JSON (set 0 to disable).
# ADK_CC_TOLERANT_TOOL_JSON=1
# Shadow-git checkpoint/undo (default-on in desktop; set 0 to disable).
# ADK_CC_CHECKPOINT=1
# web_fetch host policy: open (SSRF-guarded) | allowlist.
# ADK_CC_WEB_FETCH_MODE=open
# Skip .env loading (CI/containers where env is already populated).
# ADK_CC_SKIP_DOTENV=0
# Secret-value cache TTL in the redaction plugin.
# ADK_CC_SECRET_REDACTION_TTL_S=15.0
# Per-tenant tool-call cap per minute.
# ADK_CC_QUOTA_PER_MINUTE=120
# Opt-in retry around an upstream ADK stale-session race in HITL.
# ADK_CC_SESSION_RETRY_ON_STALE=0
# Generate tool/session titles (costs extra model tokens).
# ADK_CC_TOOL_TITLES=0
# Periodic task-list nudge (set 0 to disable).
# ADK_CC_TASK_REMINDER=1
# Disable the SSRF guard so localhost can be fetched (security-sensitive).
# ADK_CC_WEB_FETCH_ALLOW_PRIVATE=0
# Extra allowlisted fetch hosts (with WEB_FETCH_MODE=allowlist).
# ADK_CC_WEB_FETCH_HOSTS=unset
# Disable the per-turn workspace-path system hint.
# ADK_CC_DISABLE_WORKSPACE_HINT=0
# Disable CLAUDE.md/AGENTS.md/CONTEXT.md injection.
# ADK_CC_DISABLE_PROJECT_CONTEXT=0
#
# [Model: Codex]
# Where adk-cc stores its own Codex OAuth token.
# ADK_CC_CODEX_STORE_DIR=$DESKTOP_DATA or ~/.adk-cc
# Explicit Codex auth.json path (else ~/.codex/auth.json).
# ADK_CC_CODEX_AUTH_FILE=unset
# Codex reasoning-effort fallback (per-endpoint wins).
# ADK_CC_CODEX_EFFORT=medium
# Codex backend URL (dev/mock override; read at import).
# ADK_CC_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
#
# [Sandbox: Docker]
# mTLS CA cert path (all three docker certs together).
# ADK_CC_DOCKER_CA_CERT=unset
# mTLS client cert path.
# ADK_CC_DOCKER_CLIENT_CERT=unset
# mTLS client key path.
# ADK_CC_DOCKER_CLIENT_KEY=unset
# Disable the shared install-cache mount (docker backend).
# ADK_CC_DISABLE_INSTALL_CACHE_MOUNT=0
#
# [Sandbox: Daytona]
# In-sandbox workspace path.
# ADK_CC_DAYTONA_WORKSPACE_PATH=/home/daytona
# Auto-stop after N idle minutes.
# ADK_CC_DAYTONA_AUTOSTOP_MIN=15
# Auto-delete after N minutes.
# ADK_CC_DAYTONA_AUTODELETE_MIN=1440
# DELETE the sandbox on close instead of stop.
# ADK_CC_DAYTONA_DELETE_ON_CLOSE=0
# Sandbox start poll timeout.
# ADK_CC_DAYTONA_START_TIMEOUT_S=120.0
# Per-request timeout.
# ADK_CC_DAYTONA_REQUEST_TIMEOUT_S=30.0
# Credential key for per-tenant Daytona token lookup.
# ADK_CC_DAYTONA_CREDENTIAL_KEY=daytona_api_key
# Verify TLS (0 for a self-signed dev plane).
# ADK_CC_DAYTONA_VERIFY_SSL=1
# CA bundle for a private Daytona CA.
# ADK_CC_DAYTONA_CA_BUNDLE=unset
# Capacity-backoff attempt cap.
# ADK_CC_DAYTONA_CREATE_MAX_ATTEMPTS=6
# Capacity-backoff total wall-clock cap.
# ADK_CC_DAYTONA_CREATE_TOTAL_WAIT_S=45.0
#
# [Sandbox: service]
# Credential key for per-tenant token lookup.
# ADK_CC_SANDBOX_SERVICE_TOKEN_KEY=sandbox_service_token
# Requested vCPU (service caps).
# ADK_CC_SANDBOX_SERVICE_VCPU=unset
# Requested memory GiB.
# ADK_CC_SANDBOX_SERVICE_MEMORY_GIB=unset
# Requested workspace GiB.
# ADK_CC_SANDBOX_SERVICE_WORKSPACE_GIB=unset
# Per-exec timeout.
# ADK_CC_SANDBOX_SERVICE_EXEC_TIMEOUT_S=unset
# Hard-destroy TTL (service default 86400).
# ADK_CC_SANDBOX_SERVICE_HARD_DESTROY_TTL_S=unset
# Verify TLS (0 for dev).
# ADK_CC_SANDBOX_SERVICE_VERIFY_TLS=1
#
# [Sandbox: SSH]
# Remote SSH port.
# ADK_CC_SSH_PORT=22
# SSH key path (else ~/.ssh/config / agent).
# ADK_CC_SSH_IDENTITY_FILE=unset
# Extra ssh opts (tests use this for throwaway known_hosts).
# ADK_CC_SSH_EXTRA_OPTS=unset
# ControlMaster socket dir.
# ADK_CC_SSH_CONTROL_DIR=~/.adk-cc-ssh
#
# [Auth (web)]
# Static tok=user:tenant[:role] map (dev; use JWT for prod).
# ADK_CC_AUTH_TOKENS=unset  (web-only)
# Access-token TTL.
# ADK_CC_AUTH_TOKEN_TTL_S=1800  (web-only)
# Refresh-token TTL.
# ADK_CC_AUTH_REFRESH_TTL_S=2592000  (web-only)
# Password-reset link TTL.
# ADK_CC_AUTH_RESET_TTL_S=86400  (web-only)
# Enable /auth/* rate limiting (test kill switch).
# ADK_CC_AUTH_RATELIMIT=1  (web-only)
# Rate-limit sliding window.
# ADK_CC_AUTH_RATELIMIT_WINDOW_S=60  (web-only)
# Max /auth/* requests per window.
# ADK_CC_AUTH_RATELIMIT_MAX=30  (web-only)
# Failures before lockout.
# ADK_CC_AUTH_LOCKOUT_THRESHOLD=5  (web-only)
# Lockout duration.
# ADK_CC_AUTH_LOCKOUT_S=300  (web-only)
# In-house token issuer (iss).
# ADK_CC_AUTH_ISSUER=adk-cc  (web-only)
# In-house token audience (aud).
# ADK_CC_AUTH_AUDIENCE=unset  (web-only)
# Claim mapping: user id.
# ADK_CC_JWT_USER_CLAIM=sub  (web-only)
# Claim mapping: tenant.
# ADK_CC_JWT_TENANT_CLAIM=tenant  (web-only)
# Claim mapping: scopes.
# ADK_CC_JWT_SCOPES_CLAIM=scope  (web-only)
# Claim mapping: roles.
# ADK_CC_JWT_ROLES_CLAIM=roles  (web-only)
# Role name for the admin guard.
# ADK_CC_ADMIN_ROLE=admin  (web-only)
# Unknown-email logins become approvable access requests.
# ADK_CC_ACCESS_REQUESTS=1  (web-only)
# Tenant id for single mode / admin global tenant.
# ADK_CC_GLOBAL_TENANT_ID=local  (web-only)
#
# [Permissions]
# Extra hard-deny path patterns (additive to the built-in secret floor).
# ADK_CC_PROTECTED_DENY=unset
# Extra always-ask path patterns.
# ADK_CC_PROTECTED_ASK=unset
# Extra 'dangerous' command basenames (always-ask).
# ADK_CC_DANGEROUS_CMDS=unset
# Extra 'catastrophic' command basenames (hard-deny).
# ADK_CC_CATASTROPHIC_CMDS=unset
# run_bash danger classifier (set 0 to disable entirely).
# ADK_CC_CMD_SAFETY=1
#
# [MCP]
# Single MCP server (legacy; prefer SERVERS_FILE).
# ADK_CC_MCP_SERVER=unset
# Tool prefix for the single env server.
# ADK_CC_MCP_SERVER_NAME=mcp
# Transport for the single env server: stdio | sse | http.
# ADK_CC_MCP_TRANSPORT=stdio
# Expose MCP resources for the single env server.
# ADK_CC_MCP_USE_RESOURCES=0
# Save MCP resources as artifacts (single env server).
# ADK_CC_MCP_SAVE_RESOURCES_AS_ARTIFACTS=0
# Auto-persist MCP file results (set 0 to disable).
# ADK_CC_MCP_AUTOSAVE_EXPORTS=1
# Autosave only user-audience blobs (sub-knob).
# ADK_CC_MCP_AUTOSAVE_AUDIENCE_USER_ONLY=1
#
# [Skills]
# Skill safety guards (untrusted-content wrapping + host-exec refusal).
# ADK_CC_SKILL_GUARDS=0
# Ack running skill scripts on the host under noop backend.
# ADK_CC_SKILL_SCRIPTS_ACK_HOST_EXEC=0
# Per-file disk-read cap for skill resources.
# ADK_CC_SKILL_RESOURCE_READ_MAX_BYTES=4194304
# Cap on load_skill_resource line limit.
# ADK_CC_SKILL_RESOURCE_MAX_LINES=400
# Default load_skill_resource lines.
# ADK_CC_SKILL_RESOURCE_DEFAULT_LINES=200
# Boot-time RAM guard: prune oversize skill references.
# ADK_CC_SKILL_FILE_MAX_BYTES=262144
# Truncation cap on injected SKILL.md instructions.
# ADK_CC_SKILL_INSTRUCTIONS_MAX_CHARS=60000
# Disable the project .adk-cc/skills walk-up.
# ADK_CC_DISABLE_PROJECT_SKILLS=0
