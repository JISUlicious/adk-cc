# adk-cc env-var reference (data-science variant).
# Copy to `.env` and fill in real values. `.env` is gitignored;
# this file is committed.

# =============================================================================
# Required
# =============================================================================

# API key for your model server. Read at agent module-load — without this
# the agent will not import. For an OpenAI-compatible endpoint (LM Studio,
# vLLM, mlx_lm, NVIDIA-hosted models via LiteLLM), put the provider key
# here. For a local server that doesn't actually check keys, any non-empty
# string works.
ADK_CC_API_KEY=sk-replace-me

# =============================================================================
# Model config (optional — defaults to a local OpenAI-compatible server)
# =============================================================================

# LiteLLM model id. Default: openai/Qwen3.6-35B-A3B-UD-MLX-4bit
# Examples:
#   openai/<model-id>              (LM Studio, vLLM, mlx_lm, llama.cpp servers)
#   openai/minimaxai/minimax-m2.7  (NVIDIA-hosted via integrate.api.nvidia.com)
#   anthropic/claude-sonnet-4-5    (direct via litellm)
#   ollama_chat/llama3.1:8b
# ADK_CC_MODEL=openai/Qwen3.6-35B-A3B-UD-MLX-4bit

# OpenAI-compatible base URL. Default: http://localhost:18000/v1
# ADK_CC_API_BASE=http://localhost:18000/v1

# =============================================================================
# Critic sub-agent (optional — defaults to ADK_CC_* above)
# =============================================================================

# The `critic` sub-agent runs an independent verification pass on the
# coordinator's draft. Wiring a DIFFERENT model here strengthens the
# independence (separate priors, separate blind spots). When unset,
# defaults to ADK_CC_MODEL / ADK_CC_API_BASE / ADK_CC_API_KEY. Recommended:
# a stronger or differently-trained model than the main agent.
# ADK_CC_CRITIC_MODEL=anthropic/claude-sonnet-4-5
# ADK_CC_CRITIC_API_BASE=https://api.anthropic.com
# ADK_CC_CRITIC_API_KEY=...

# =============================================================================
# Logging
# =============================================================================

# Python log level for adk_cc modules. Default: INFO
# ADK_CC_LOG_LEVEL=DEBUG

# Log output format. Default: text. Set to `json` for structured logs.
# ADK_CC_LOG_FORMAT=json

# =============================================================================
# Audit (always on; controls sink path)
# =============================================================================

# Where the AuditPlugin writes JSONL events. Default:
#   ~/.adk-cc/audit.jsonl
# One event per line; event types include tool_call_attempt,
# tool_call_result, tool_call_error, loop_stage_transition,
# model_request, model_response. Append-only.
# ADK_CC_AUDIT_LOG=/var/log/adk-cc/audit.jsonl

# =============================================================================
# Model I/O trace (opt-in — large payloads)
# =============================================================================

# Set to 1 to dump every LlmRequest and LlmResponse to the audit log as
# `model_request` and `model_response` events. Useful for debugging model
# behavior. Off by default; each callback is one attribute check when off.
# ADK_CC_LOG_MODEL_IO=1

# Max bytes per dumped payload. Default: 50000 (50KB).
# ADK_CC_LOG_MODEL_IO_MAX_BYTES=50000

# =============================================================================
# Context-length guardrail (opt-in)
# =============================================================================

# When ADK_CC_MAX_CONTEXT_TOKENS is set, ContextGuardPlugin pre-flights
# the LlmRequest token count. WARN at 75% by default, REJECT at 95%.
# Override the warn / reject thresholds with absolute token counts if
# you need finer control.
# ADK_CC_MAX_CONTEXT_TOKENS=128000
# ADK_CC_CONTEXT_WARN_TOKENS=96000
# ADK_CC_CONTEXT_REJECT_TOKENS=121600

# =============================================================================
# Session retry on stale (opt-in)
# =============================================================================

# Set to 1 to monkey-patch ADK's SqliteSessionService / DatabaseSessionService
# `append_event` with a retry-on-stale wrapper. Defends against the race
# where a HITL pause/resume cycle has two writers contending on the same
# session row. Idempotent; safe to enable.
# ADK_CC_SESSION_RETRY_ON_STALE=1
