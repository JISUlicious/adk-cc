# adk-cc environment reference — GENERATED from agents/adk_cc/config/schema.py.
# Do not edit by hand; run `python -m adk_cc.config gen-env`. Copy to `.env`.
# Profile: all. Required vars are uncommented; everything else shows its default.

# ============================================================
# QUICKSTART — required + commonly set
# ============================================================

# --- Quickstart --------------------------------------------------------
#
# [Model]
# API key for your OpenAI-compatible model server. The server BOOTS without it (warned, model calls fail until set) — desktop first-run enters it in the UI.  [default: unset]
ADK_CC_API_KEY=sk-replace-me
# OpenAI-compatible model server base URL.  [default: http://localhost:18000/v1]
# ADK_CC_API_BASE=
# LiteLLM model id (openai/<id>, ollama_chat/<id>, anthropic/<id>, …).  [default: openai/Qwen3.6-35B-A3B-UD-MLX-4bit]
# ADK_CC_MODEL=
# Throttle: max model-call starts per minute (paces all callers). Off by default.  [default: off]
# ADK_CC_MODEL_MAX_RPM=30
#
# [Context]
# Enable the context-guard ladder at this token budget. Unset = guard off.  [default: off]
# ADK_CC_MAX_CONTEXT_TOKENS=
# Model for conversation summarization (falls back to the main model).  [default: $ADK_CC_MODEL]
# ADK_CC_COMPACTION_MODEL=
#
# [Permissions]
# default | plan | acceptEdits | bypassPermissions | dontAsk. Dev default: bypassPermissions.  (one of: default|plan|acceptEdits|bypassPermissions|dontAsk)  [default: bypassPermissions]
# ADK_CC_PERMISSION_MODE=
# Path to a YAML of permission rules + authz policies.  [default: unset]
# ADK_CC_PERMISSIONS_YAML=
#
# [Sandbox]
# noop | container | docker | e2b | sandbox_service | daytona | ssh. Default: noop (host exec).  (one of: noop|container|docker|e2b|sandbox_service|daytona|ssh)  [default: noop]
# ADK_CC_SANDBOX_BACKEND=
# Static KEY=VALUE,… (or JSON) env baked into the sandbox for every command.  [default: unset]
# ADK_CC_SANDBOX_ENV=
# Host env var names to copy into the sandbox (comma-separated).  [default: unset]
# ADK_CC_SANDBOX_ENV_PASSTHROUGH=
#
# [Sandbox: Daytona]
# Daytona control-plane URL.  [default: unset]
# ADK_CC_DAYTONA_API_URL=
# Daytona API key (single-tenant) or use a credential provider.  [default: unset]
# ADK_CC_DAYTONA_API_KEY=
# Snapshot id/name to prewarm from (recommended).  [default: unset]
# ADK_CC_DAYTONA_SNAPSHOT=
# Toolbox proxy base (derived :3000→:4000 if unset).  [default: derived]
# ADK_CC_DAYTONA_PROXY_URL=
#
# [Sandbox: SSH]
# Remote host (alias or user@host) for the ssh backend env-factory path.  [default: unset]
# ADK_CC_SSH_HOST=
# Absolute workspace path on the remote.  [default: unset]
# ADK_CC_SSH_WORKSPACE_PATH=
#
# [Auth (web)]
# 1 = use the in-house email+password identity service.  (web-only)  [default: 0]
# ADK_CC_AUTH_PASSWORD=
# External IdP JWKS URL (Keycloak/…); presence selects the JWT auth path.  (web-only)  [default: unset]
# ADK_CC_JWT_JWKS_URL=
# Enable the ABAC authorization plugin + /authz routes.  (web-only)  [default: 0]
# ADK_CC_AUTHZ=
# Mount the admin panel routes.  (web-only)  [default: 0]
# ADK_CC_ADMIN_PANEL=
# First-boot admin email (password mode). Inert after the first admin exists.  (web-only)  [default: unset]
# ADK_CC_BOOTSTRAP_ADMIN_EMAIL=
# First-boot admin password (with EMAIL).  (web-only)  [default: unset]
# ADK_CC_BOOTSTRAP_ADMIN_PASSWORD=
# Explicitly run with NO auth (fail-open). Desktop sets this; web dev only.  [default: 0]
# ADK_CC_ALLOW_NO_AUTH=
# Expected iss from the external IdP (unset = not verified).  (web-only)  [default: unset]
# ADK_CC_JWT_ISSUER=
# Expected aud from the external IdP.  (web-only)  [default: unset]
# ADK_CC_JWT_AUDIENCE=
# single | multi org model.  (one of: single|multi)  (web-only)  [default: single]
# ADK_CC_TENANCY_MODE=
# Trust X-Forwarded-For for ratelimit/lockout IP (behind a proxy).  (web-only)  [default: 0]
# ADK_CC_TRUST_PROXY=
#
# [Deployment]
# Web/multi-tenant workspace anchor. Unset = CWD (dev zero-config).  [default: CWD]
# ADK_CC_WORKSPACE_ROOT=
# Server-side data root — identity, admin/tenant registry, credentials, audit, tasks, codex token all default under here.  [default: ~/.adk-cc (web) / desktop data dir]
# ADK_CC_DATA_DIR=
# Persistent session store DSN (postgres/sqlite). Unset = in-memory. Ignored in desktop.  (web-only)  [default: in-memory]
# ADK_CC_SESSION_DSN=
# Artifact persistence URI (file://, gs://, s3://). Unset = in-memory.  [default: in-memory]
# ADK_CC_ARTIFACT_STORAGE_URI=
# Agents root ADK discovers the agent package under (defaults to this package's agents/ dir).  [default: <package>/agents]
# ADK_CC_AGENTS_DIR=
# Log verbosity (DEBUG/INFO/WARNING/…).  [default: INFO]
# ADK_CC_LOG_LEVEL=
# Log format: text | json.  (one of: text|json)  [default: text]
# ADK_CC_LOG_FORMAT=
# Admin/tenant data root (when the admin panel is on).  (web-only)  [default: <DATA_DIR>/admin-data]
# ADK_CC_ADMIN_DATA_DIR=
# Tool/permission audit JSONL sink.  [default: <DATA_DIR>/audit.jsonl]
# ADK_CC_AUDIT_LOG=
#
# [Sandbox: Docker]
# Docker daemon (tcp://…, ssh://…).  [default: unset]
# ADK_CC_DOCKER_HOST=
#
# [Sandbox: service]
# External sandbox REST service URL.  [default: unset]
# ADK_CC_SANDBOX_SERVICE_URL=
# Shared bearer token (single-tenant) or use a credential provider.  [default: unset]
# ADK_CC_SANDBOX_SERVICE_SHARED_TOKEN=
#
# [Credentials]
# memory | encrypted_file | none.  (one of: memory|encrypted_file|none)  [default: memory]
# ADK_CC_CREDENTIAL_PROVIDER=
# Secret store dir for encrypted_file (defaults to <DATA_DIR>/secrets, logged at boot — set explicitly so the store's location is deliberate).  [default: <DATA_DIR>/secrets]
# ADK_CC_CREDENTIAL_STORE_DIR=
# Fernet key for the encrypted secret store.  [default: unset]
# ADK_CC_CREDENTIAL_KEY=
#
# [Memory & Wiki]
# Memory store dir.  [default: <workspace>/.memory]
# ADK_CC_MEMORY_ROOT=
# Responsive consolidation trigger (unset = off).  [default: off]
# ADK_CC_MEMORY_CONSOLIDATE_THRESHOLD=
# In-process periodic consolidation interval (≤0 = off).  [default: off]
# ADK_CC_MEMORY_CONSOLIDATE_INTERVAL_S=
# Wiki store dir.  [default: <workspace>/.wiki]
# ADK_CC_WIKI_ROOT=
#
# [MCP]
# JSON array of MCP servers to connect to (per-entry name/transport/filters/creds).  [default: unset]
# ADK_CC_MCP_SERVERS_FILE=
#
# [Skills]
# Explicit skills root (shadows project/install skills).  [default: unset]
# ADK_CC_SKILLS_DIR=


# ============================================================
# REFERENCE — advanced tuning (sane defaults; rarely changed)
# ============================================================

# --- Reference ---------------------------------------------------------
#
# [Model]
# Alternative to MAX_RPM: min seconds between model-call starts.  [default: off]
# ADK_CC_MODEL_MIN_INTERVAL_S=
# Cap on model OUTPUT tokens/call (litellm max_tokens). 0 = uncapped; per-endpoint wins.  [default: 8192]
# ADK_CC_MAX_OUTPUT_TOKENS=
# Cap to escalate to after a mid-tool-call truncation (finish_reason=MAX_TOKENS). 0 disables.  [default: 32768]
# ADK_CC_MAX_OUTPUT_TOKENS_ESCALATED=
# Path to the live model-endpoint registry JSON (auto-defaulted when the admin panel is on).  [default: auto]
# ADK_CC_MODEL_REGISTRY_FILE=
#
# [Context]
# Token threshold that triggers conversation compaction. Requires EVENT_RETENTION set too.  [default: off]
# ADK_CC_COMPACTION_TOKEN_THRESHOLD=
# Events to keep when compacting (must be set together with TOKEN_THRESHOLD).  [default: off]
# ADK_CC_COMPACTION_EVENT_RETENTION=
# Enable zero-cost tool-result eviction tier.  [default: 0]
# ADK_CC_MICROCOMPACT=
# API base for the compaction model (different provider).  [default: $ADK_CC_API_BASE]
# ADK_CC_COMPACTION_API_BASE=
# API key for the compaction model.  [default: $ADK_CC_API_KEY]
# ADK_CC_COMPACTION_API_KEY=
# Summarizer timeout seconds (0 = none).  [default: 30]
# ADK_CC_COMPACTION_TIMEOUT_S=
# Seed memory stores into the compaction summary (opt-in).  [default: 0]
# ADK_CC_COMPACTION_SEED_MEMORY=
# Token budget for seeded memory.  [default: 300]
# ADK_CC_COMPACTION_SEED_BUDGET=
# Compaction framing line; 0 disables, a string overrides the built-in.  [default: built-in]
# ADK_CC_COMPACTION_FRAME=
# Compaction circuit-breaker failures before tripping (0 disables).  [default: 3]
# ADK_CC_COMPACTION_BREAKER_THRESHOLD=
# Circuit-breaker cooldown seconds.  [default: 60]
# ADK_CC_COMPACTION_BREAKER_COOLDOWN_S=
# Inline compaction prompt override.  [default: built-in template]
# ADK_CC_COMPACTION_PROMPT=
# Path to a compaction prompt template.  [default: unset]
# ADK_CC_COMPACTION_PROMPT_FILE=
# Event overlap when compacting.  [default: 2]
# ADK_CC_COMPACTION_OVERLAP=
# Event-count compaction interval (also an enable path).  [default: 10]
# ADK_CC_COMPACTION_INTERVAL=
# Per-file cap for CLAUDE.md/AGENTS.md/CONTEXT.md project-context injection.  [default: 50000]
# ADK_CC_CONTEXT_FILES_MAX_BYTES=
# Context-guard warn threshold (derived ~75% if unset).  [default: derived]
# ADK_CC_CONTEXT_WARN_TOKENS=
# Output-headroom reserve for the context guard.  [default: 0]
# ADK_CC_CONTEXT_RESERVE_TOKENS=
# Context-guard hard-stop threshold (derived ~95% if unset).  [default: derived]
# ADK_CC_CONTEXT_REJECT_TOKENS=
# Count tool payloads in context sizing (opt-in).  [default: 0]
# ADK_CC_CONTEXT_COUNT_TOOL_PAYLOADS=
# Extra absolute context files (comma-separated) layered on discovery.  [default: unset]
# ADK_CC_CONTEXT_FILES=
# Microcompact size floor.  [default: 800]
# ADK_CC_MICROCOMPACT_MIN_TOKENS=
# Microcompact recency window.  [default: 4]
# ADK_CC_MICROCOMPACT_KEEP_RECENT=
#
# [Sandbox]
# Container image override. Per-backend defaults when unset: docker = adk-cc-sandbox:latest; container/desktop = python:3.12-slim.  [default: per-backend (see help)]
# ADK_CC_SANDBOX_IMAGE=
# container backend: 1 = network on (dev), 0 = none.  [default: 1]
# ADK_CC_SANDBOX_NETWORK=
# 1 = fail closed: run_bash errors if the sandbox runtime is missing (no host fallback).  [default: 0]
# ADK_CC_SANDBOX_REQUIRE=
# Desktop sandbox mode: host | container (usually set via the UI).  (one of: host|container)  (desktop-only)  [default: host]
# ADK_CC_SANDBOX_MODE=
# Container runtime: auto | docker | podman.  (one of: auto|docker|podman)  [default: auto]
# ADK_CC_SANDBOX_RUNTIME=
# Reap idle session containers after N seconds (0 = off).  [default: 0]
# ADK_CC_SANDBOX_IDLE_TTL_S=
# Container memory limit.  [default: 4g]
# ADK_CC_SANDBOX_MEM_LIMIT=
# Container CPU limit (container backend).  [default: 2]
# ADK_CC_SANDBOX_CPUS=
# Docker CPU quota (=1 CPU; docker backend).  [default: 100000]
# ADK_CC_SANDBOX_CPU_QUOTA=
# Container PID limit (docker + container backends).  [default: 512]
# ADK_CC_SANDBOX_PIDS_LIMIT=
# Stream run_bash output to operator logs.  [default: 0]
# ADK_CC_BASH_STREAM=
# Ack host exec on prod-shaped paths (noop backend).  [default: is_desktop()]
# ADK_CC_NOOP_ACK_HOST_EXEC=
# ENV_NAME=credential_key,… resolved per-tenant into the sandbox.  [default: unset]
# ADK_CC_SANDBOX_ENV_CREDENTIALS=
#
# [Memory & Wiki]
# Enable the autonomous memory subsystem (recall + capture).  [default: 0]
# ADK_CC_MEMORY=
# Enable the explicit wiki tools.  [default: 0]
# ADK_CC_WIKI=
# Memory store URI (only file:// implemented — prefer MEMORY_ROOT).  [default: unset]
# ADK_CC_MEMORY_STORE_URI=
# Consolidation synthesis: LLM distill unless 'deterministic' (latest-wins, no model). Only this step — autocapture/resolve have their own flags.  [default: llm]
# ADK_CC_MEMORY_SYNTH=
# Capture memories after turns (0 = recall-only).  [default: 1]
# ADK_CC_MEMORY_AUTOCAPTURE=
# Identity-resolution model call (0 disables).  [default: 1]
# ADK_CC_MEMORY_RESOLVE=
# Verify resolution (sub-knob of RESOLVE).  [default: 1]
# ADK_CC_MEMORY_RESOLVE_VERIFY=
# Scheduler boot-settle delay (test hook).  [default: 60]
# ADK_CC_MEMORY_CONSOLIDATE_DELAY_S=
# Archive memories older than N days.  [default: 90]
# ADK_CC_MEMORY_STALE_DAYS=
# LLM compaction pass in the scheduler (0 disables).  [default: 1]
# ADK_CC_MEMORY_COMPACT=
# Episodic retention cap (0 = keep all).  [default: keep all]
# ADK_CC_MEMORY_EPISODIC_CAP=
# Recall prompt budget.  [default: 600]
# ADK_CC_MEMORY_RECALL_BUDGET_TOKENS=
# Capture model-call timeout.  [default: 30.0]
# ADK_CC_MEMORY_CAPTURE_TIMEOUT_S=
# Wiki store URI (only file:// implemented — prefer WIKI_ROOT).  [default: unset]
# ADK_CC_WIKI_STORE_URI=
# Corroborations before a wiki fact is trusted (admin API overrides).  [default: 2]
# ADK_CC_WIKI_CORROBORATION_N=
#
# [Deployment]
# Desktop data root (sessions, settings, secrets, checkpoints).  (desktop-only)  [default: ~/.adk-cc-desktop]
# ADK_CC_DESKTOP_DATA=
# Mount the SPA (set by the desktop app / UI deployments).  [default: 0]
# ADK_CC_SERVE_UI=
# Identity store dir (users/invites/keys/audit).  (web-only)  [default: <DATA_DIR>/identity]
# ADK_CC_IDENTITY_DIR=
# Per-tenant MCP registry dir.  (web-only)  [default: <admin-data>/registry]
# ADK_CC_TENANT_REGISTRY_DIR=
# Per-tenant skills dir.  (web-only)  [default: <admin-data>/skills]
# ADK_CC_TENANT_SKILLS_DIR=
# Desktop settings.env path override.  (desktop-only)  [default: unset]
# ADK_CC_SETTINGS_FILE=
# Desktop-mode selector (set by the app, not users).  [default: 0]
# ADK_CC_DESKTOP=
# Central task storage override.  [default: <workspace>/.adk-cc/tasks or <DATA_DIR>/tasks]
# ADK_CC_TASKS_DIR=
# S3 endpoint for s3:// artifacts (falls back to AWS_ENDPOINT_URL).  [default: unset]
# ADK_CC_S3_ENDPOINT_URL=
# Built SPA dir to serve.  [default: <repo>/web/dist]
# ADK_CC_UI_DIST=
# Experimental knowledge-graph endpoints.  [default: 0]
# ADK_CC_KNOWLEDGE_UI=
# Dump raw LLM request/response to DEBUG log.  [default: 0]
# ADK_CC_LOG_MODEL_IO=
# Truncation cap for LOG_MODEL_IO.  [default: 50000]
# ADK_CC_LOG_MODEL_IO_MAX_BYTES=
#
# [Behavior]
# Default-on repair of malformed tool-call JSON (set 0 to disable).  [default: 1]
# ADK_CC_TOLERANT_TOOL_JSON=
# Shadow-git checkpoint/undo (default-on in desktop; set 0 to disable).  [default: 1]
# ADK_CC_CHECKPOINT=
# web_fetch host policy: open (SSRF-guarded) | allowlist.  (one of: open|allowlist)  [default: open]
# ADK_CC_WEB_FETCH_MODE=
# Skip .env loading (CI/containers where env is already populated).  [default: 0]
# ADK_CC_SKIP_DOTENV=
# Skip the import-time config self-check log (tests/CLI noise control).  [default: 0]
# ADK_CC_SKIP_CONFIG_CHECK=
# Secret-value cache TTL in the redaction plugin.  [default: 15.0]
# ADK_CC_SECRET_REDACTION_TTL_S=
# Per-tenant tool-call cap per minute.  [default: 120]
# ADK_CC_QUOTA_PER_MINUTE=
# Opt-in retry around an upstream ADK stale-session race in HITL.  [default: 0]
# ADK_CC_SESSION_RETRY_ON_STALE=
# Generate tool/session titles (costs extra model tokens).  [default: 0]
# ADK_CC_TOOL_TITLES=
# Periodic task-list nudge (set 0 to disable).  [default: 1]
# ADK_CC_TASK_REMINDER=
# Disable the SSRF guard so localhost can be fetched (security-sensitive).  [default: 0]
# ADK_CC_WEB_FETCH_ALLOW_PRIVATE=
# Extra allowlisted fetch hosts (with WEB_FETCH_MODE=allowlist).  [default: unset]
# ADK_CC_WEB_FETCH_HOSTS=
# Disable the per-turn workspace-path system hint.  [default: 0]
# ADK_CC_DISABLE_WORKSPACE_HINT=
# Disable CLAUDE.md/AGENTS.md/CONTEXT.md injection.  [default: 0]
# ADK_CC_DISABLE_PROJECT_CONTEXT=
#
# [Model: Codex]
# Where adk-cc stores its own Codex OAuth token.  [default: <DATA_DIR>]
# ADK_CC_CODEX_STORE_DIR=
# Explicit Codex auth.json path (else ~/.codex/auth.json).  [default: unset]
# ADK_CC_CODEX_AUTH_FILE=
# Codex reasoning-effort fallback (per-endpoint wins).  [default: medium]
# ADK_CC_CODEX_EFFORT=
# Codex backend URL (dev/mock override; read at import).  [default: https://chatgpt.com/backend-api/codex]
# ADK_CC_CODEX_BASE_URL=
#
# [Sandbox: Docker]
# mTLS CA cert path (all three docker certs together).  [default: unset]
# ADK_CC_DOCKER_CA_CERT=
# mTLS client cert path.  [default: unset]
# ADK_CC_DOCKER_CLIENT_CERT=
# mTLS client key path.  [default: unset]
# ADK_CC_DOCKER_CLIENT_KEY=
# Disable the shared install-cache mount (docker backend).  [default: 0]
# ADK_CC_DISABLE_INSTALL_CACHE_MOUNT=
#
# [Sandbox: Daytona]
# In-sandbox workspace path.  [default: /home/daytona]
# ADK_CC_DAYTONA_WORKSPACE_PATH=
# Auto-stop after N idle minutes.  [default: 15]
# ADK_CC_DAYTONA_AUTOSTOP_MIN=
# Auto-delete after N minutes.  [default: 1440]
# ADK_CC_DAYTONA_AUTODELETE_MIN=
# DELETE the sandbox on close instead of stop.  [default: 0]
# ADK_CC_DAYTONA_DELETE_ON_CLOSE=
# Sandbox start poll timeout.  [default: 120.0]
# ADK_CC_DAYTONA_START_TIMEOUT_S=
# Per-request timeout.  [default: 30.0]
# ADK_CC_DAYTONA_REQUEST_TIMEOUT_S=
# Credential key for per-tenant Daytona token lookup.  [default: daytona_api_key]
# ADK_CC_DAYTONA_CREDENTIAL_KEY=
# Verify TLS (0 for a self-signed dev plane).  [default: 1]
# ADK_CC_DAYTONA_VERIFY_SSL=
# CA bundle for a private Daytona CA.  [default: unset]
# ADK_CC_DAYTONA_CA_BUNDLE=
# Capacity-backoff attempt cap.  [default: 6]
# ADK_CC_DAYTONA_CREATE_MAX_ATTEMPTS=
# Capacity-backoff total wall-clock cap.  [default: 45.0]
# ADK_CC_DAYTONA_CREATE_TOTAL_WAIT_S=
#
# [Sandbox: service]
# Credential key for per-tenant token lookup.  [default: sandbox_service_token]
# ADK_CC_SANDBOX_SERVICE_TOKEN_KEY=
# Requested vCPU (service caps).  [default: unset]
# ADK_CC_SANDBOX_SERVICE_VCPU=
# Requested memory GiB.  [default: unset]
# ADK_CC_SANDBOX_SERVICE_MEMORY_GIB=
# Requested workspace GiB.  [default: unset]
# ADK_CC_SANDBOX_SERVICE_WORKSPACE_GIB=
# Per-exec timeout.  [default: unset]
# ADK_CC_SANDBOX_SERVICE_EXEC_TIMEOUT_S=
# Hard-destroy TTL (service default 86400).  [default: unset]
# ADK_CC_SANDBOX_SERVICE_HARD_DESTROY_TTL_S=
# Verify TLS (0 for dev).  [default: 1]
# ADK_CC_SANDBOX_SERVICE_VERIFY_TLS=
#
# [Sandbox: SSH]
# Remote SSH port.  [default: 22]
# ADK_CC_SSH_PORT=
# SSH key path (else ~/.ssh/config / agent).  [default: unset]
# ADK_CC_SSH_IDENTITY_FILE=
# Extra ssh opts (tests use this for throwaway known_hosts).  [default: unset]
# ADK_CC_SSH_EXTRA_OPTS=
# ControlMaster socket dir.  [default: ~/.adk-cc-ssh]
# ADK_CC_SSH_CONTROL_DIR=
#
# [Auth (web)]
# Static tok=user:tenant[:role] map (dev; use JWT for prod).  (web-only)  [default: unset]
# ADK_CC_AUTH_TOKENS=
# Access-token TTL.  (web-only)  [default: 1800]
# ADK_CC_AUTH_TOKEN_TTL_S=
# Refresh-token TTL.  (web-only)  [default: 2592000]
# ADK_CC_AUTH_REFRESH_TTL_S=
# Password-reset link TTL.  (web-only)  [default: 86400]
# ADK_CC_AUTH_RESET_TTL_S=
# Enable /auth/* rate limiting (test kill switch).  (web-only)  [default: 1]
# ADK_CC_AUTH_RATELIMIT=
# Rate-limit sliding window.  (web-only)  [default: 60]
# ADK_CC_AUTH_RATELIMIT_WINDOW_S=
# Max /auth/* requests per window.  (web-only)  [default: 30]
# ADK_CC_AUTH_RATELIMIT_MAX=
# Failures before lockout.  (web-only)  [default: 5]
# ADK_CC_AUTH_LOCKOUT_THRESHOLD=
# Lockout duration.  (web-only)  [default: 300]
# ADK_CC_AUTH_LOCKOUT_S=
# In-house token issuer (iss).  (web-only)  [default: adk-cc]
# ADK_CC_AUTH_ISSUER=
# In-house token audience (aud).  (web-only)  [default: unset]
# ADK_CC_AUTH_AUDIENCE=
# Claim mapping: user id.  (web-only)  [default: sub]
# ADK_CC_JWT_USER_CLAIM=
# Claim mapping: tenant.  (web-only)  [default: tenant]
# ADK_CC_JWT_TENANT_CLAIM=
# Claim mapping: scopes.  (web-only)  [default: scope]
# ADK_CC_JWT_SCOPES_CLAIM=
# Claim mapping: roles.  (web-only)  [default: roles]
# ADK_CC_JWT_ROLES_CLAIM=
# Role name for the admin guard.  (web-only)  [default: admin]
# ADK_CC_ADMIN_ROLE=
# Unknown-email logins become approvable access requests.  (web-only)  [default: 1]
# ADK_CC_ACCESS_REQUESTS=
# Tenant id for single mode / admin global tenant.  (web-only)  [default: local]
# ADK_CC_GLOBAL_TENANT_ID=
#
# [Permissions]
# Extra hard-deny path patterns (additive to the built-in secret floor).  [default: unset]
# ADK_CC_PROTECTED_DENY=
# Extra always-ask path patterns.  [default: unset]
# ADK_CC_PROTECTED_ASK=
# Extra 'dangerous' command basenames (always-ask).  [default: unset]
# ADK_CC_DANGEROUS_CMDS=
# Extra 'catastrophic' command basenames (hard-deny).  [default: unset]
# ADK_CC_CATASTROPHIC_CMDS=
# run_bash danger classifier (set 0 to disable entirely).  [default: 1]
# ADK_CC_CMD_SAFETY=
#
# [MCP]
# Single MCP server (legacy; prefer SERVERS_FILE).  [default: unset]
# ADK_CC_MCP_SERVER=
# Tool prefix for the single env server.  [default: mcp]
# ADK_CC_MCP_SERVER_NAME=
# Transport for the single env server: stdio | sse | http.  (one of: stdio|sse|http)  [default: stdio]
# ADK_CC_MCP_TRANSPORT=
# Expose MCP resources for the single env server.  [default: 0]
# ADK_CC_MCP_USE_RESOURCES=
# Save MCP resources as artifacts (single env server).  [default: 0]
# ADK_CC_MCP_SAVE_RESOURCES_AS_ARTIFACTS=
# Auto-persist MCP file results (set 0 to disable).  [default: 1]
# ADK_CC_MCP_AUTOSAVE_EXPORTS=
# Autosave only user-audience blobs (sub-knob).  [default: 1]
# ADK_CC_MCP_AUTOSAVE_AUDIENCE_USER_ONLY=
#
# [Skills]
# Skill safety guards (untrusted-content wrapping + host-exec refusal).  [default: 0]
# ADK_CC_SKILL_GUARDS=
# Ack running skill scripts on the host under noop backend.  [default: 0]
# ADK_CC_SKILL_SCRIPTS_ACK_HOST_EXEC=
# Per-file disk-read cap for skill resources.  [default: 4194304]
# ADK_CC_SKILL_RESOURCE_READ_MAX_BYTES=
# Cap on load_skill_resource line limit.  [default: 400]
# ADK_CC_SKILL_RESOURCE_MAX_LINES=
# Default load_skill_resource lines.  [default: 200]
# ADK_CC_SKILL_RESOURCE_DEFAULT_LINES=
# Boot-time RAM guard: prune oversize skill references.  [default: 262144]
# ADK_CC_SKILL_FILE_MAX_BYTES=
# Truncation cap on injected SKILL.md instructions.  [default: 60000]
# ADK_CC_SKILL_INSTRUCTIONS_MAX_CHARS=
# Disable the project .adk-cc/skills walk-up.  [default: 0]
# ADK_CC_DISABLE_PROJECT_SKILLS=
